{
  "name": "internal-wallet-mcp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bunx wrangler dev --port 8788 --inspector-port 9231",
    "build": "bunx wrangler deploy --dry-run",
    "deploy": "bunx wrangler deploy",
    "check": "bunx ultracite check src package.json tsconfig.json wrangler.toml README.md",
    "fix": "bunx ultracite fix src package.json tsconfig.json wrangler.toml README.md",
    "types": "bunx wrangler types",
    "typecheck": "bun run types && tsc --noEmit"
  },
  "dependencies": {
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "typescript": "catalog:workers",
    "wrangler": "^4.66.0"
  }
}

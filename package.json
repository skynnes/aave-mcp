{
  "name": "aave-mcp",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "check": "turbo run check",
    "fix": "turbo run fix",
    "inspector": "bunx @mcpjam/inspector@latest"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:tooling",
    "turbo": "catalog:tooling",
    "ultracite": "catalog:tooling"
  },
  "catalogs": {
    "tooling": {
      "@biomejs/biome": "^2.3.14",
      "turbo": "^2.8.3",
      "ultracite": "^7.1.5"
    },
    "workers": {
      "typescript": "^5.9.3",
      "wrangler": "^4.63.0"
    }
  },
  "engines": {
    "bun": ">=1.3.9"
  }
}

{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "build/**"
      ]
    },
    "deploy": {
      "dependsOn": [
        "^deploy"
      ],
      "cache": false
    },
    "types": {
      "dependsOn": [
        "^types"
      ],
      "outputs": [
        "worker-configuration.d.ts"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    },
    "check": {},
    "fix": {},
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
